# Go backend
BONSAI_SERVER_ADDR=:8080
BONSAI_STATIC_DIR=
BONSAI_PUBLIC_API_BASE=

# Internal service URLs on Raspberry Pi localhost
# Sensor API node is not implemented yet. Leave empty for demo/fallback mode unless you provide your own endpoint.
BONSAI_SENSOR_API_URL=
BONSAI_LLM_CHAT_STREAM_URL=http://127.0.0.1:8081/v1/chat/completions
BONSAI_LLM_MODEL=gemma-4-e2b-it
BONSAI_MEMORY_QDRANT_URL=
BONSAI_MEMORY_COLLECTION=bonsai-memory
BONSAI_MEMORY_SEARCH_LIMIT=3
BONSAI_MEMORY_VECTOR_SIZE=192
