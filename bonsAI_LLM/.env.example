# llama.cpp server mode for Raspberry Pi 5 (8GB)
LLAMA_CPP_DIR=/opt/llama.cpp
BONSAI_LLM_MODEL_FILE=/opt/bonsAI/models/qwen2.5-3b-instruct-q4_k_m.gguf
BONSAI_LLM_HF_REPO=
BONSAI_LLM_HF_FILE=
BONSAI_LLM_HOST=127.0.0.1
BONSAI_LLM_PORT=8081
BONSAI_LLM_ALIAS=qwen2.5-3b
BONSAI_LLM_CTX_SIZE=2048
BONSAI_LLM_THREADS=4
BONSAI_LLM_PARALLEL=1
BONSAI_LLM_BATCH=256
BONSAI_LLM_UBATCH=128
BONSAI_LLM_GPU_LAYERS=0
