# Docker Compose shared settings
# Copy this file to .env when you want Docker Compose to load local overrides.

# Optional Hugging Face token for gated/private model downloads.
HF_TOKEN=

# LLM defaults used by docker-compose.yml.
BONSAI_LLM_ALIAS=gemma-4-e2b-it
BONSAI_LLM_MODEL=gemma-4-e2b-it
BONSAI_LLM_HF_REPO=unsloth/gemma-4-E2B-it-GGUF
BONSAI_LLM_HF_FILE=gemma-4-E2B-it-Q4_K_M.gguf
BONSAI_LLM_CTX_SIZE=2048
BONSAI_LLM_THREADS=4
BONSAI_LLM_PARALLEL=1
BONSAI_LLM_BATCH=256
BONSAI_LLM_UBATCH=128
BONSAI_LLM_GPU_LAYERS=0

# Mac lightweight Docker test:
# Leave empty for demo fallback, or point to a host-side llama.cpp server.
# Example: http://host.docker.internal:8083/v1/chat/completions
BONSAI_MAC_LLM_CHAT_STREAM_URL=
